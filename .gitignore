# Only the encryption key is excluded — everything else is in git
.env

# Decrypted secret files (generated by scripts/decrypt-secrets.sh).
# Pattern-based, not a per-file allowlist: ANY config/*.json is ignored by default,
# then only the encrypted .enc files and the non-secret tracked state files are
# explicitly un-ignored below. A newly created plaintext secret config is safe by
# construction — no per-file .gitignore entry to remember/forget.
# (Fixes a recurring leak: config/.workstream-config.json committed 2026-06-19,
# config/.newrelic-ohcleo-config.json committed 2026-07-07 — both were plaintext
# secrets missing from the old per-file list until GitHub Push Protection caught them.)
config/*.json
!config/*.json.enc
!config/.elena-pending-actions.json
!config/.monitoring-timelines.json
!config/.weekly-report-send-flags.json
!config/leave-plan.json
!config/finance-watchlist.json

# Legacy root-level config (moved to config/)
.upwork-config.json

# Runtime
node_modules/
tmp/

# Claude Code hook logs (runtime, may contain sensitive prompts/tool I/O)
.claude/hooks/.logs/

# Agent intermediate reports
plans/reports/general-purpose-*

# Autorun logs may leak tokens from subagent curl commands
reports/**/autorun.log

