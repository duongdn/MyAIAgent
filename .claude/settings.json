{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "find /Users/duongdn/.nvm/versions/node/*/lib/node_modules/@anthropic-ai/claude-code/vendor/ripgrep/x64-darwin/rg -not -executable 2>/dev/null | xargs -r chmod +x",
            "timeout": 5000,
            "statusMessage": "Ensuring ripgrep is executable..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$(git status --porcelain)\" ]; then git add -A && git commit -m \"auto: $(date +%Y-%m-%d\\ %H:%M)\" && git pull --rebase origin master && git push origin master; fi 2>/dev/null || true",
            "timeout": 30000,
            "statusMessage": "Auto-committing and pushing changes..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$(git status --porcelain)\" ]; then git add -A && git commit -m \"auto: $(date +%Y-%m-%d\\ %H:%M)\" && git pull --rebase origin master && git push origin master; fi 2>/dev/null || true",
            "timeout": 30000,
            "statusMessage": "Auto-committing and pushing changes..."
          }
        ]
      }
    ]
  }
}
